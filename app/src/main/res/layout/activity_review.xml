<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_theme"
        android:scaleType="fitXY"
        android:contentDescription="MoodMeal background" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="26dp"
            android:paddingEnd="26dp"
            android:paddingTop="42dp"
            android:paddingBottom="110dp">

            <TextView
                android:id="@+id/btnBackReview"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="←"
                android:textColor="@color/text_dark"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Upload Food Review"
                android:textColor="@color/dark_teal"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Capture your food and share your review."
                android:textColor="@color/text_gray"
                android:textSize="15sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivFoodPreview"
                android:layout_width="match_parent"
                android:layout_height="230dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/food_card_bg"
                android:scaleType="centerCrop"
                android:contentDescription="Food image preview" />

            <TextView
                android:id="@+id/btnUploadImage"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/primary_button"
                android:gravity="center"
                android:text="Open Camera"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etReviewText"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/field_bg"
                android:gravity="top"
                android:hint="Write your review..."
                android:inputType="textMultiLine"
                android:padding="16dp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_gray"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/etRating"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/field_bg"
                android:hint="Rating e.g. 4.5"
                android:inputType="numberDecimal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_gray"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/btnSubmitReview"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/primary_button"
                android:gravity="center"
                android:text="Submit Review"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold" />

        </LinearLayout>

    </ScrollView>

</FrameLayout>