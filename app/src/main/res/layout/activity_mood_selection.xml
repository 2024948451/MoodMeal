<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_theme"
        android:scaleType="fitXY" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="86dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="26dp"
            android:paddingRight="26dp"
            android:paddingTop="42dp"
            android:paddingBottom="100dp">

            <TextView
                android:id="@+id/tvBackMood"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="‹"
                android:textSize="34sp"
                android:textColor="@color/text_dark" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="How are you feeling?"
                android:textColor="@color/dark_teal"
                android:textStyle="bold"
                android:textSize="24sp"
                android:gravity="center" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Choose your mood or let us decide!"
                android:textColor="@color/text_dark"
                android:textStyle="bold"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginTop="8dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:layout_marginTop="28dp">

                <TextView
                    android:id="@+id/moodHungry"
                    android:layout_width="0dp"
                    android:layout_height="62dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="7dp"
                    android:background="@drawable/mood_hungry"
                    android:gravity="center"
                    android:text="🙂  Hungry"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/moodStressed"
                    android:layout_width="0dp"
                    android:layout_height="62dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="7dp"
                    android:background="@drawable/mood_stressed"
                    android:gravity="center"
                    android:text="😫  Stressed"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/moodTired"
                    android:layout_width="0dp"
                    android:layout_height="62dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="7dp"
                    android:background="@drawable/mood_tired"
                    android:gravity="center"
                    android:text="🥱  Tired"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/moodHappy"
                    android:layout_width="0dp"
                    android:layout_height="62dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="7dp"
                    android:background="@drawable/mood_happy"
                    android:gravity="center"
                    android:text="😊  Happy"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/moodSad"
                    android:layout_width="0dp"
                    android:layout_height="62dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="7dp"
                    android:background="@drawable/mood_sad"
                    android:gravity="center"
                    android:text="😢  Sad"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/moodCraving"
                    android:layout_width="0dp"
                    android:layout_height="62dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="7dp"
                    android:background="@drawable/mood_craving"
                    android:gravity="center"
                    android:text="🍟  Craving"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/moodBudget"
                    android:layout_width="0dp"
                    android:layout_height="62dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="7dp"
                    android:background="@drawable/mood_budget"
                    android:gravity="center"
                    android:text="💰  Budget Mode"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/moodAdventurous"
                    android:layout_width="0dp"
                    android:layout_height="62dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="7dp"
                    android:background="@drawable/mood_adventurous"
                    android:gravity="center"
                    android:text="🧭  Adventurous"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold"
                    android:textSize="16sp" />

            </GridLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="— ✨ Or let MoodMeal decide! ✨ —"
                android:textColor="@color/text_dark"
                android:textStyle="bold"
                android:textSize="15sp"
                android:gravity="center"
                android:layout_marginTop="20dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="330dp"
                android:layout_marginTop="12dp">

                <com.uitm.ict602.moodmeal.SpinWheelView
                    android:id="@+id/spinWheelView"
                    android:layout_width="300dp"
                    android:layout_height="300dp"
                    android:layout_gravity="center" />

                <TextView
                    android:id="@+id/btnSpinMood"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_gravity="center"
                    android:background="@drawable/circle_white"
                    android:gravity="center"
                    android:text="SPIN"
                    android:textColor="@color/teal"
                    android:textStyle="bold"
                    android:textSize="20sp" />

            </FrameLayout>

            <TextView
                android:id="@+id/tvShakeHint"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/white_button"
                android:gravity="center_vertical"
                android:paddingLeft="18dp"
                android:text="Shake your phone\nfor a surprise!     📱"
                android:textColor="@color/text_dark"
                android:textStyle="bold"
                android:textSize="15sp" />

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="74dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bottom_nav_bg"
        android:paddingLeft="10dp"
        android:paddingRight="10dp">

        <TextView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⌂\nHome"
            android:textColor="@color/yellow"
            android:textStyle="bold"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/navExplore"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⌕\nExplore"
            android:textColor="@color/text_gray"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/navPlus"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:gravity="center"
            android:background="@drawable/circle_teal"
            android:text="+"
            android:textColor="@color/white"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/navFav"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="♡\nFavourites"
            android:textColor="@color/text_gray"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="♙\nProfile"
            android:textColor="@color/text_gray"
            android:textSize="12sp" />

    </LinearLayout>

</FrameLayout>