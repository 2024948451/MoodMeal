<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_theme"
        android:scaleType="fitXY" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="86dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:paddingTop="42dp"
            android:paddingBottom="96dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvMenuHome"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="☰"
                    android:textSize="28sp"
                    android:textColor="@color/text_dark" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔔"
                    android:textSize="24sp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvGreetingHome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hey, Aiman 👋"
                android:textColor="@color/dark_teal"
                android:textStyle="bold"
                android:textSize="20sp"
                android:layout_marginTop="18dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="What's your mood today?"
                android:textColor="@color/text_gray"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:id="@+id/btnSpinNow"
                android:layout_width="match_parent"
                android:layout_height="148dp"
                android:layout_marginTop="26dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp"
                android:background="@drawable/top_teal_card">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Can’t decide?\nLet’s spin your\nmood!"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:lineSpacingExtra="4dp" />

                    <TextView
                        android:layout_width="96dp"
                        android:layout_height="36dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/white_button"
                        android:gravity="center"
                        android:text="Spin Now  ›"
                        android:textColor="@color/text_dark"
                        android:textStyle="bold"
                        android:textSize="12sp" />

                </LinearLayout>

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="📱\n🎡"
                    android:textSize="42sp" />

            </LinearLayout>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:columnCount="3"
                android:rowCount="2">

                <LinearLayout
                    android:id="@+id/cardMoodSelection"
                    android:layout_width="0dp"
                    android:layout_height="118dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/tile_yellow">

                    <TextView
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:background="@drawable/circle_yellow"
                        android:gravity="center"
                        android:text="☺"
                        android:textSize="28sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Mood Selection"
                        android:textColor="@color/text_dark"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Pick or spin"
                        android:textColor="@color/text_gray"
                        android:textSize="10sp"
                        android:gravity="center" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardNearbyFood"
                    android:layout_width="0dp"
                    android:layout_height="118dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/tile_green">

                    <TextView
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:gravity="center"
                        android:text="📍"
                        android:textSize="30sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nearby Food"
                        android:textColor="@color/text_dark"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Find near you"
                        android:textColor="@color/text_gray"
                        android:textSize="10sp"
                        android:gravity="center" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardFavourites"
                    android:layout_width="0dp"
                    android:layout_height="118dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/tile_orange">

                    <TextView
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:gravity="center"
                        android:text="❤"
                        android:textSize="34sp"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Favourites"
                        android:textColor="@color/text_dark"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Saved places"
                        android:textColor="@color/soft_red"
                        android:textSize="10sp"
                        android:gravity="center" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardUploadReview"
                    android:layout_width="0dp"
                    android:layout_height="118dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/tile_purple">

                    <TextView
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:gravity="center"
                        android:text="📷"
                        android:textSize="29sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Upload Review"
                        android:textColor="@color/text_dark"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Share food"
                        android:textColor="@color/text_gray"
                        android:textSize="10sp"
                        android:gravity="center" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardReviews"
                    android:layout_width="0dp"
                    android:layout_height="118dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/tile_mint">

                    <TextView
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:gravity="center"
                        android:text="💬"
                        android:textSize="30sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Reviews"
                        android:textColor="@color/text_dark"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="See what others say"
                        android:textColor="@color/text_gray"
                        android:textSize="10sp"
                        android:gravity="center" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardSettings"
                    android:layout_width="0dp"
                    android:layout_height="118dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/tile_beige">

                    <TextView
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:gravity="center"
                        android:text="⚙"
                        android:textSize="33sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Settings"
                        android:textColor="@color/text_dark"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="App preferences"
                        android:textColor="@color/text_gray"
                        android:textSize="10sp"
                        android:gravity="center" />
                </LinearLayout>

            </GridLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Recommended for you"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold"
                    android:textSize="17sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See all"
                    android:textColor="@color/teal"
                    android:textStyle="bold"
                    android:textSize="13sp" />

            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="135dp"
                        android:layout_marginRight="10dp"
                        android:background="@drawable/white_button"
                        android:gravity="center"
                        android:text="🍛\n\nNasi Ayam Campus\n0.4 km · ★ 4.6"
                        android:textColor="@color/text_dark"
                        android:textStyle="bold"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="135dp"
                        android:layout_marginRight="10dp"
                        android:background="@drawable/white_button"
                        android:gravity="center"
                        android:text="🍕\n\nPizza Lab\n0.7 km · ★ 4.4"
                        android:textColor="@color/text_dark"
                        android:textStyle="bold"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="135dp"
                        android:background="@drawable/white_button"
                        android:gravity="center"
                        android:text="🍔\n\nKopi Uni\n0.3 km · ★ 4.6"
                        android:textColor="@color/text_dark"
                        android:textStyle="bold"
                        android:textSize="12sp" />

                </LinearLayout>

            </HorizontalScrollView>

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="74dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bottom_nav_bg"
        android:paddingLeft="10dp"
        android:paddingRight="10dp">

        <TextView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⌂\nHome"
            android:textColor="@color/yellow"
            android:textStyle="bold"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/navExplore"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⌕\nExplore"
            android:textColor="@color/text_gray"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/navPlus"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:gravity="center"
            android:background="@drawable/circle_teal"
            android:text="+"
            android:textColor="@color/white"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/navFav"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="♡\nFavourites"
            android:textColor="@color/text_gray"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="♙\nProfile"
            android:textColor="@color/text_gray"
            android:textSize="12sp" />

    </LinearLayout>

</FrameLayout>