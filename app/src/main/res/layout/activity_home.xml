<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_theme"
        android:scaleType="fitXY" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="44dp"
            android:paddingBottom="96dp">

            <!-- TOP BAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvMenuHome"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:text="☰"
                    android:textColor="@color/text_dark"
                    android:textSize="26sp" />

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="♧"
                        android:textColor="@color/text_dark"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="17dp"
                        android:layout_height="17dp"
                        android:layout_gravity="top|end"
                        android:background="@drawable/circle_red"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="@color/white"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                </FrameLayout>

            </LinearLayout>

            <!-- GREETING -->
            <TextView
                android:id="@+id/tvGreetingHome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Hey, Aiman 👋"
                android:textColor="@color/dark_teal"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="What's your mood today?"
                android:textColor="@color/text_gray"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- HERO CARD -->
            <LinearLayout
                android:id="@+id/btnSpinNow"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/top_teal_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="3dp"
                        android:text="Can’t decide?\nLet’s spin your\nmood!"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="98dp"
                        android:layout_height="34dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/white_pill"
                        android:gravity="center"
                        android:text="Spin Now  ›"
                        android:textColor="@color/text_dark"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="118dp"
                    android:src="@drawable/hero_spin"
                    android:scaleType="centerCrop"
                    android:background="@drawable/image_round_bg"
                    android:clipToOutline="true" />

            </LinearLayout>

            <!-- FEATURE GRID -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:columnCount="3"
                android:rowCount="2">

                <!-- Mood Selection -->
                <LinearLayout
                    android:id="@+id/cardMoodSelection"
                    android:layout_width="0dp"
                    android:layout_height="112dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/tile_yellow"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="7dp">

                    <ImageView
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:background="@drawable/icon_box_yellow"
                        android:padding="12dp"
                        android:src="@drawable/ic_smile_clean" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:gravity="center"
                        android:text="Mood Selection"
                        android:textColor="@color/text_dark"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Pick or spin"
                        android:textColor="@color/text_gray"
                        android:textSize="9sp" />

                </LinearLayout>

                <!-- Nearby Food -->
                <LinearLayout
                    android:id="@+id/cardNearbyFood"
                    android:layout_width="0dp"
                    android:layout_height="112dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/tile_green"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="7dp">

                    <ImageView
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:background="@drawable/icon_box_green"
                        android:padding="12dp"
                        android:src="@drawable/ic_pin_clean" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:gravity="center"
                        android:text="Nearby Food"
                        android:textColor="@color/text_dark"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Find near you"
                        android:textColor="@color/text_gray"
                        android:textSize="9sp" />

                </LinearLayout>

                <!-- Favourites -->
                <LinearLayout
                    android:id="@+id/cardFavourites"
                    android:layout_width="0dp"
                    android:layout_height="112dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/tile_orange"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="7dp">

                    <ImageView
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:background="@drawable/icon_box_red"
                        android:padding="12dp"
                        android:src="@drawable/ic_heart_clean" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:gravity="center"
                        android:text="Favourites"
                        android:textColor="@color/text_dark"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Your saved places"
                        android:textColor="@color/soft_red"
                        android:textSize="9sp" />

                </LinearLayout>

                <!-- Upload Review -->
                <LinearLayout
                    android:id="@+id/cardUploadReview"
                    android:layout_width="0dp"
                    android:layout_height="112dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/tile_purple"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="7dp">

                    <ImageView
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:background="@drawable/icon_box_purple"
                        android:padding="12dp"
                        android:src="@drawable/ic_camera_clean" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:gravity="center"
                        android:text="Upload Review"
                        android:textColor="@color/text_dark"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Share your food"
                        android:textColor="@color/text_gray"
                        android:textSize="9sp" />

                </LinearLayout>

                <!-- Reviews -->
                <LinearLayout
                    android:id="@+id/cardReviews"
                    android:layout_width="0dp"
                    android:layout_height="112dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/tile_mint"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="7dp">

                    <ImageView
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:background="@drawable/icon_box_mint"
                        android:padding="12dp"
                        android:src="@drawable/ic_review_clean" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:gravity="center"
                        android:text="Reviews"
                        android:textColor="@color/text_dark"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="See what others say"
                        android:textColor="@color/text_gray"
                        android:textSize="9sp" />

                </LinearLayout>

                <!-- Settings -->
                <LinearLayout
                    android:id="@+id/cardSettings"
                    android:layout_width="0dp"
                    android:layout_height="112dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/tile_beige"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="7dp">

                    <ImageView
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:background="@drawable/icon_box_beige"
                        android:padding="12dp"
                        android:src="@drawable/ic_settings_clean" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:gravity="center"
                        android:text="Settings"
                        android:textColor="@color/text_dark"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="App preferences"
                        android:textColor="@color/text_gray"
                        android:textSize="9sp" />

                </LinearLayout>

            </GridLayout>

            <!-- RECOMMENDED HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Recommended for you"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See all"
                    android:textColor="@color/teal"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- FOOD CARDS -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="126dp"
                        android:layout_height="142dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/food_card_bg"
                        android:orientation="vertical"
                        android:padding="6dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="76dp"
                            android:src="@drawable/food_nasi_ayam"
                            android:scaleType="centerCrop"
                            android:background="@drawable/image_round_bg"
                            android:clipToOutline="true" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="7dp"
                            android:maxLines="1"
                            android:text="Nasi Ayam Campus"
                            android:textColor="@color/text_dark"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="0.4 km  ·  ★ 4.6"
                            android:textColor="@color/text_gray"
                            android:textSize="9sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="126dp"
                        android:layout_height="142dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/food_card_bg"
                        android:orientation="vertical"
                        android:padding="6dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="76dp"
                            android:src="@drawable/food_pizza"
                            android:scaleType="centerCrop"
                            android:background="@drawable/image_round_bg"
                            android:clipToOutline="true" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="7dp"
                            android:maxLines="1"
                            android:text="Pizza Lab"
                            android:textColor="@color/text_dark"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="0.7 km  ·  ★ 4.4"
                            android:textColor="@color/text_gray"
                            android:textSize="9sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="126dp"
                        android:layout_height="142dp"
                        android:background="@drawable/food_card_bg"
                        android:orientation="vertical"
                        android:padding="6dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="76dp"
                            android:src="@drawable/food_burger"
                            android:scaleType="centerCrop"
                            android:background="@drawable/image_round_bg"
                            android:clipToOutline="true" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="7dp"
                            android:maxLines="1"
                            android:text="Kopi Uni"
                            android:textColor="@color/text_dark"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="0.3 km  ·  ★ 4.6"
                            android:textColor="@color/text_gray"
                            android:textSize="9sp" />

                    </LinearLayout>

                </LinearLayout>

            </HorizontalScrollView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="●  ○  ○"
                android:textColor="@color/teal"
                android:textSize="15sp" />

        </LinearLayout>

    </ScrollView>

    <!-- BOTTOM NAV -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="82dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bottom_nav_bg"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <!-- Home -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⌂"
                android:textColor="@color/yellow"
                android:textSize="27sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="@color/yellow"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Explore -->
        <LinearLayout
            android:id="@+id/navExplore"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⌕"
                android:textColor="@color/text_gray"
                android:textSize="29sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Explore"
                android:textColor="@color/text_gray"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Plus Button -->
        <FrameLayout
            android:id="@+id/navPlus"
            android:layout_width="72dp"
            android:layout_height="match_parent"
            android:gravity="center">

            <TextView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:background="@drawable/circle_teal"
                android:gravity="center"
                android:text="+"
                android:textColor="@color/white"
                android:textSize="40sp"
                android:textStyle="bold" />

        </FrameLayout>

        <!-- Favourites -->
        <LinearLayout
            android:id="@+id/navFav"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="♡"
                android:textColor="@color/text_gray"
                android:textSize="29sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Favourites"
                android:textColor="@color/text_gray"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Profile -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="♙"
                android:textColor="@color/text_gray"
                android:textSize="27sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textColor="@color/text_gray"
                android:textSize="11sp" />

        </LinearLayout>

    </LinearLayout>
    <!-- SIDE DRAWER OVERLAY -->
    <View
        android:id="@+id/drawerOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone" />

    <!-- SIDE DRAWER PANEL -->
    <LinearLayout
        android:id="@+id/drawerPanel"
        android:layout_width="292dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@drawable/side_menu_bg"
        android:elevation="12dp"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="54dp"
        android:paddingEnd="22dp"
        android:paddingBottom="24dp"
        android:translationX="-292dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="54dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_moodmeal_logo" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MoodMeal"
                    android:textColor="@color/dark_teal"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Eat what fits your mood"
                    android:textColor="@color/text_gray"
                    android:textSize="11sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:id="@+id/btnCloseDrawer"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="×"
                android:textColor="@color/text_dark"
                android:textSize="28sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Quick Menu"
            android:textColor="@color/text_dark"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerMood"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/side_menu_item_bg"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:text="☺   Mood Selection"
            android:textColor="@color/text_dark"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerAccount"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/side_menu_item_bg"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:text="♙   Manage Account"
            android:textColor="@color/text_dark"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerAbout"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/side_menu_item_bg"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:text="ⓘ   About MoodMeal"
            android:textColor="@color/text_dark"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/drawerLogout"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:background="@drawable/side_menu_logout_bg"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:text="↪   Logout"
            android:textColor="@color/danger"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

</FrameLayout>