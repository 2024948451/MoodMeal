<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_theme"
        android:scaleType="fitXY" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="86dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="26dp"
            android:paddingRight="26dp"
            android:paddingTop="42dp"
            android:paddingBottom="100dp">

            <TextView
                android:id="@+id/tvBackManage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="‹"
                android:textSize="34sp"
                android:textColor="@color/text_dark" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manage Account"
                android:textColor="@color/dark_teal"
                android:textStyle="bold"
                android:textSize="24sp"
                android:gravity="center" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Update your information\nor manage your account."
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginTop="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="28dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="18dp"
                android:background="@drawable/top_teal_card">

                <TextView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/circle_white"
                    android:gravity="center"
                    android:text="👨‍🎓"
                    android:textSize="36sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvAccountName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Aiman Hakim"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/tvAccountEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="aiman.hakim@gmail.com"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:layout_width="150dp"
                        android:layout_height="28dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/white_button"
                        android:gravity="center"
                        android:text="🎓  University Student"
                        android:textColor="@color/dark_teal"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Account Actions"
                android:textColor="@color/text_dark"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="28dp" />

            <TextView
                android:id="@+id/btnUpdateProfile"
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/white_button"
                android:gravity="center_vertical"
                android:paddingLeft="20dp"
                android:text="✎   Update Profile\n     Edit your name, email, photo and more.        ›"
                android:textColor="@color/text_dark"
                android:textStyle="bold"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btnResetPassword"
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/white_button"
                android:gravity="center_vertical"
                android:paddingLeft="20dp"
                android:text="🔒   Reset Password\n     Change your password for better security.        ›"
                android:textColor="@color/text_dark"
                android:textStyle="bold"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btnDeleteAccount"
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/white_button"
                android:gravity="center_vertical"
                android:paddingLeft="20dp"
                android:text="🗑   Delete Account\n     Permanently delete your account and all data.        ›"
                android:textColor="@color/text_dark"
                android:textStyle="bold"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Danger Zone"
                android:textColor="@color/danger"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_marginTop="28dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="74dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/warning_bg"
                android:gravity="center_vertical"
                android:paddingLeft="20dp"
                android:text="⚠   Deleting your account is permanent\n     and cannot be undone."
                android:textColor="@color/danger"
                android:textStyle="bold"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/danger_outline"
                android:gravity="center"
                android:text="↪   Log Out"
                android:textColor="@color/danger"
                android:textStyle="bold"
                android:textSize="16sp" />

        </LinearLayout>

    </ScrollView>

    <!-- BOTTOM NAV -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="82dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bottom_nav_bg"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <!-- Home -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⌂"
                android:textColor="@color/text_gray"
                android:textSize="27sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="@color/text_gray"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Explore -->
        <LinearLayout
            android:id="@+id/navExplore"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⌕"
                android:textColor="@color/text_gray"
                android:textSize="29sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Explore"
                android:textColor="@color/text_gray"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Plus Button -->
        <FrameLayout
            android:id="@+id/navPlus"
            android:layout_width="72dp"
            android:layout_height="match_parent"
            android:gravity="center">

            <TextView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:background="@drawable/circle_teal"
                android:gravity="center"
                android:text="+"
                android:textColor="@color/white"
                android:textSize="40sp" />

        </FrameLayout>

        <!-- Favourites -->
        <LinearLayout
            android:id="@+id/navFav"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="♡"
                android:textColor="@color/text_gray"
                android:textSize="29sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Favourites"
                android:textColor="@color/text_gray"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Profile -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="♙"
                android:textColor="@color/yellow"
                android:textSize="27sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textColor="@color/yellow"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>